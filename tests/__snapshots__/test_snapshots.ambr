              }
              QScrollBar::handle:vertical {
                  background-color: #AAAAAA;
                  border-radius: 5px;
                  min-height: 20px;
                  margin: 2px;
              }
              QScrollBar::handle:vertical:hover {
                  background-color: #b19145;
              }
              QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
                  height: 0px;
              }
              QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
                  background: none;
              }
              
              QScrollBar:horizontal {
                  background-color: #E0E0E0;
                  height: 12px;
                  border-radius: 6px;
                  margin: 0;
              }
              QScrollBar::handle:horizontal {
                  background-color: #AAAAAA;
                  border-radius: 5px;
                  min-width: 20px;
                  margin: 2px;
              }
              QScrollBar::handle:horizontal:hover {
                  background-color: #b19145;
              }
              QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
                  width: 0px;
              }
              QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
                  background: none;
              }
              
              /* ===== FRAME ===== */
              QFrame {
                  background-color: transparent;
              }
              QFrame[frameShape="4"] {  /* HLine */
                  background-color: #CCCCCC;
                  max-height: 1px;
              }
              QFrame[frameShape="5"] {  /* VLine */
                  background-color: #CCCCCC;
                  max-width: 1px;
              }
              
          
              QTabWidget {
                  border: none;
              }
              QTabWidget::pane {
                  background-color: #F5F5F5;
                  border: none;
                  border-top: none;
                  padding: 0px;
                  margin: 0px;
              }
              QTabWidget::tab-bar {
                  left: 0px;
              }
              QTabBar {
                  background-color: #F5F5F5;
                  border: none;
                  qproperty-drawBase: 0;
              }
              QTabBar::tab {
                  background-color: #FFFFFF;
                  color: #666666;
                  padding: 8px 16px;
                  border: none;
                  border-bottom: 2px solid transparent;
                  border-top-left-radius: 4px;
                  border-top-right-radius: 4px;
                  margin-right: 2px;
              }
              QTabBar::tab:selected {
                  background-color: #F5F5F5;
                  color: #b19145;
                  border-bottom: 2px solid #b19145;
              }
              QTabBar::tab:hover:!selected {
                  background-color: #EEEEEE;
                  color: #b19145;
                  border-bottom: 2px solid #8a7236;
              }
          
  
              QTableWidget {
                  background-color: #FFFFFF;
                  color: #000000;
                  border: 1px solid #CCCCCC;
                  gridline-color: #CCCCCC;
                  border-radius: 4px;
              }
              QTableWidget::item {
                  padding: 4px;
              }
              QTableWidget::item:selected {
                  background-color: #b19145;
                  color: #FFFFFF;
              }
              QTableWidget::item:hover {
                  background-color: #c4a458;
                  color: #FFFFFF;
              }
              QHeaderView::section {
                  background-color: #E8E8E8;
                  color: #000000;
                  border: none;
                  border-right: 1px solid #CCCCCC;
                  border-bottom: 1px solid #CCCCCC;
                  padding: 6px;
                  font-weight: bold;
              }
              QTableCornerButton::section {
                  background-color: #E8E8E8;
                  border: none;
              }
          
  
              QListWidget {
                  background-color: #FFFFFF;
                  color: #000000;
                  border: 1px solid #CCCCCC;
                  border-radius: 4px;
                  outline: none;
              }
              QListWidget::item {
                  padding: 6px;
                  border-radius: 2px;
              }
              QListWidget::item:selected {
                  background-color: #b19145;
                  color: #FFFFFF;
              }
              QListWidget::item:hover:!selected {
                  background-color: #c4a458;
                  color: #FFFFFF;
              }
          
  
              QTreeWidget {
                  background-color: #FFFFFF;
                  color: #000000;
                  border: 1px solid #CCCCCC;
                  border-radius: 4px;
                  outline: none;
              }
              QTreeWidget::item {
                  padding: 4px;
              }
              QTreeWidget::item:selected {
                  background-color: #b19145;
                  color: #FFFFFF;
              }
              QTreeWidget::item:hover:!selected {
                  background-color: #c4a458;
                  color: #FFFFFF;
              }
              QTreeWidget::branch {
                  background-color: transparent;
              }
              QTreeWidget::branch:selected {
                  background-color: #b19145;
              }
              QHeaderView::section {
                  background-color: #E8E8E8;
                  color: #000000;
                  border: none;
                  border-right: 1px solid #CCCCCC;
                  border-bottom: 1px solid #CCCCCC;
                  padding: 6px;
                  font-weight: bold;
              }
          
  
              QSlider::groove:horizontal {
                  border: 1px solid #CCCCCC;
                  height: 6px;
                  background: #FFFFFF;
                  border-radius: 3px;
              }
              QSlider::handle:horizontal {
                  background: #b19145;
                  border: none;
                  width: 16px;
                  margin: -5px 0;
                  border-radius: 8px;
              }
              QSlider::handle:horizontal:hover {
                  background: #c4a458;
              }
              QSlider::sub-page:horizontal {
                  background: #b19145;
                  border-radius: 3px;
              }
              QSlider::groove:vertical {
                  border: 1px solid #CCCCCC;
                  width: 6px;
                  background: #FFFFFF;
                  border-radius: 3px;
              }
              QSlider::handle:vertical {
                  background: #b19145;
                  border: none;
                  height: 16px;
                  margin: 0 -5px;
                  border-radius: 8px;
              }
              QSlider::handle:vertical:hover {
                  background: #c4a458;
              }
          
  
              QSpinBox, QDoubleSpinBox {
                  background-color: #FFFFFF;
                  color: #000000;
                  border: 1px solid #CCCCCC;
                  padding: 5px;
                  border-radius: 4px;
                  selection-background-color: #b19145;
                  selection-color: #FFFFFF;
              }
              QSpinBox:focus, QDoubleSpinBox:focus {
                  border-color: #b19145;
              }
              QSpinBox::up-button, QDoubleSpinBox::up-button {
                  border: none;
                  background-color: transparent;
              }
              QSpinBox::down-button, QDoubleSpinBox::down-button {
                  border: none;
                  background-color: transparent;
              }
              QSpinBox:disabled, QDoubleSpinBox:disabled {
                  background-color: #E8E8E8;
                  color: #AAAAAA;
              }
          
  
              QMenu {
                  background-color: #FFFFFF;
                  color: #000000;
                  border: 1px solid #CCCCCC;
                  padding: 4px;
              }
              QMenu::item {
                  padding: 6px 24px 6px 12px;
                  border-radius: 2px;
              }
              QMenu::item:selected {
                  background-color: #b19145;
                  color: #FFFFFF;
              }
              QMenu::item:disabled {
                  color: #AAAAAA;
              }
              QMenu::separator {
                  height: 1px;
                  background-color: #CCCCCC;
                  margin: 4px 8px;
              }
          
  
              QSplitter::handle {
                  background-color: #CCCCCC;
              }
              QSplitter::handle:horizontal {
                  width: 3px;
              }
              QSplitter::handle:vertical {
                  height: 3px;
              }
              QSplitter::handle:hover {
                  background-color: #b19145;
              }
          
  
              QProgressBar {
                  background-color: #FFFFFF;
                  border: 1px solid #CCCCCC;
                  border-radius: 4px;
                  text-align: center;
                  color: #000000;
                  height: 20px;
              }
              QProgressBar::chunk {
                  background-color: #b19145;
                  border-radius: 3px;
              }
          
  '''
