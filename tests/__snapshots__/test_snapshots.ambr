              QComboBox QAbstractItemView::item:hover {
                  background-color: #c4a458;
                  color: #FFFFFF;
              }
              QComboBox:disabled {
                  background-color: #E8E8E8;
                  color: #AAAAAA;
              }
              
              /* ===== CHECK BOX ===== */
              QCheckBox {
                  color: #000000;
                  spacing: 8px;
              }
              QCheckBox::indicator {
                  width: 16px;
                  height: 16px;
                  border-radius: 3px;
                  border: 1px solid #DDDDDD;
                  background-color: #FFFFFF;
              }
              QCheckBox::indicator:checked {
                  background-color: #b19145;
                  border-color: #b19145;
              }
              QCheckBox::indicator:hover {
                  border-color: #b19145;
              }
              QCheckBox:disabled {
                  color: #AAAAAA;
              }
              
              /* ===== RADIO BUTTON ===== */
              QRadioButton {
                  color: #000000;
                  spacing: 8px;
              }
              QRadioButton::indicator {
                  width: 16px;
                  height: 16px;
                  border-radius: 8px;
                  border: 1px solid #DDDDDD;
                  background-color: #FFFFFF;
              }
              QRadioButton::indicator:checked {
                  background-color: #b19145;
                  border-color: #b19145;
              }
              QRadioButton::indicator:hover {
                  border-color: #b19145;
              }
              QRadioButton:disabled {
                  color: #AAAAAA;
              }
              
              /* ===== PUSH BUTTON ===== */
              QPushButton {
                  background-color: #FFFFFF;
                  color: #000000;
                  border: 1px solid #CCCCCC;
                  padding: 8px 16px;
                  border-radius: 4px;
                  font-weight: bold;
              }
              QPushButton:hover {
                  background-color: #EEEEEE;
                  border-color: #b19145;
                  color: #b19145;
              }
              QPushButton:pressed {
                  background-color: #b19145;
                  color: #FFFFFF;
              }
              QPushButton:disabled {
                  background-color: #E8E8E8;
                  color: #AAAAAA;
                  border-color: #CCCCCC;
              }
              QPushButton:default {
                  border-color: #b19145;
              }
              
              /* ===== PROGRESS BAR ===== */
              QProgressBar {
                  background-color: #FFFFFF;
                  border: 1px solid #CCCCCC;
                  border-radius: 4px;
                  text-align: center;
                  color: #000000;
              }
              QProgressBar::chunk {
                  background-color: #b19145;
                  border-radius: 3px;
              }
              
              /* ===== SCROLL AREA ===== */
              QScrollArea {
                  border: none;
                  background-color: transparent;
              }
              QScrollArea > QWidget > QWidget {
                  background-color: transparent;
              }
              
              /* ===== SCROLL BAR ===== */
              QScrollBar:vertical {
                  background-color: #E0E0E0;
                  width: 12px;
                  border-radius: 6px;
                  margin: 0;
              }
              QScrollBar::handle:vertical {
                  background-color: #AAAAAA;
                  border-radius: 5px;
                  min-height: 20px;
                  margin: 2px;
              }
              QScrollBar::handle:vertical:hover {
                  background-color: #b19145;
              }
              QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
                  height: 0px;
              }
              QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
                  background: none;
              }
              
              QScrollBar:horizontal {
                  background-color: #E0E0E0;
                  height: 12px;
                  border-radius: 6px;
                  margin: 0;
              }
              QScrollBar::handle:horizontal {
                  background-color: #AAAAAA;
                  border-radius: 5px;
                  min-width: 20px;
                  margin: 2px;
              }
              QScrollBar::handle:horizontal:hover {
                  background-color: #b19145;
              }
              QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
                  width: 0px;
              }
              QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
                  background: none;
              }
              
              /* ===== FRAME ===== */
              QFrame {
                  background-color: transparent;
              }
              QFrame[frameShape="4"] {  /* HLine */
                  background-color: #CCCCCC;
                  max-height: 1px;
              }
              QFrame[frameShape="5"] {  /* VLine */
                  background-color: #CCCCCC;
                  max-width: 1px;
              }
              
          
