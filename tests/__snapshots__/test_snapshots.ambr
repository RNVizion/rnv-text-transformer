                  selection-color: #000000;
                  border: 1px solid #333333;
                  outline: none;
              }
              QComboBox QAbstractItemView::item {
                  padding: 4px 8px;
                  min-height: 22px;
              }
              QComboBox QAbstractItemView::item:selected {
                  background-color: #d2bc93;
                  color: #000000;
              }
              QComboBox QAbstractItemView::item:hover {
                  background-color: #dcc9a3;
                  color: #000000;
              }
              QComboBox:disabled {
                  background-color: #333333;
                  color: #555555;
              }
              
              /* ===== CHECK BOX ===== */
              QCheckBox {
                  color: #E0E0E0;
                  spacing: 8px;
              }
              QCheckBox::indicator {
                  width: 16px;
                  height: 16px;
                  border-radius: 3px;
                  border: 1px solid #444444;
                  background-color: #2A2A2A;
              }
              QCheckBox::indicator:checked {
                  background-color: #d2bc93;
                  border-color: #d2bc93;
              }
              QCheckBox::indicator:hover {
                  border-color: #d2bc93;
              }
              QCheckBox:disabled {
                  color: #555555;
              }
              
              /* ===== RADIO BUTTON ===== */
              QRadioButton {
                  color: #E0E0E0;
                  spacing: 8px;
              }
              QRadioButton::indicator {
                  width: 16px;
                  height: 16px;
                  border-radius: 8px;
                  border: 1px solid #444444;
                  background-color: #2A2A2A;
              }
              QRadioButton::indicator:checked {
                  background-color: #d2bc93;
                  border-color: #d2bc93;
              }
              QRadioButton::indicator:hover {
                  border-color: #d2bc93;
              }
              QRadioButton:disabled {
                  color: #555555;
              }
              
              /* ===== PUSH BUTTON ===== */
              QPushButton {
                  background-color: #2A2A2A;
                  color: #E0E0E0;
                  border: 1px solid #333333;
                  padding: 8px 16px;
                  border-radius: 4px;
                  font-weight: bold;
              }
              QPushButton:hover {
                  background-color: #3A3A3A;
                  border-color: #d2bc93;
                  color: #d2bc93;
              }
              QPushButton:pressed {
                  background-color: #d2bc93;
                  color: #000000;
              }
              QPushButton:disabled {
                  background-color: #333333;
                  color: #555555;
                  border-color: #333333;
              }
              QPushButton:default {
                  border-color: #d2bc93;
              }
              
              /* ===== PROGRESS BAR ===== */
              QProgressBar {
                  background-color: #2A2A2A;
