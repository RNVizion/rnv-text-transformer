# ---
# name: TestDiffSnapshots.test_compute_html_diff_render
  '''
  <!DOCTYPE html>
  <html>
  <head>
  <meta charset="utf-8">
  <title>Test Diff</title>
  <style>
  body { font-family: 'Consolas', 'Monaco', monospace; font-size: 12px; margin: 20px; }
  .diff-table { border-collapse: collapse; width: 100%; }
  .diff-table td { padding: 2px 8px; vertical-align: top; white-space: pre-wrap; word-wrap: break-word; }
  .diff-table .line-num { color: #888888; text-align: right; width: 40px; border-right: 1px solid #dddddd; }
  .diff-equal { background-color: #ffffff; }
  .diff-insert { background-color: #d4edda; }
  .diff-delete { background-color: #f8d7da; }
  .diff-replace-left { background-color: #f8d7da; }
  .diff-replace-right { background-color: #d4edda; }
  .header { background-color: #f0f0f0; font-weight: bold; padding: 10px; margin-bottom: 10px; }
  .stats { margin-bottom: 20px; color: #666666; }
  </style>
  </head>
  <body>
  
  <div class="header">Test Diff</div>
  <div class="stats">
  Total changes: 2 
  (+1 insertions, -0 deletions, ~1 replacements)
  </div>
  <table class="diff-table">
  <tr><th class="line-num">Left</th><th>Original</th><th class="line-num">Right</th><th>Modified</th></tr>
  <tr class="diff-equal"><td class="line-num">1</td><td>alpha</td><td class="line-num">1</td><td>alpha</td></tr>
  <tr class="diff-replace-left"><td class="line-num">2</td><td>beta</td><td class="line-num">2</td><td class="diff-replace-right">BETA</td></tr>
  <tr class="diff-equal"><td class="line-num">3</td><td>gamma</td><td class="line-num">3</td><td>gamma</td></tr>
  <tr class="diff-equal"><td class="line-num">4</td><td>delta</td><td class="line-num">4</td><td>delta</td></tr>
  <tr class="diff-insert"><td class="line-num"></td><td></td><td class="line-num">5</td><td>epsilon</td></tr>
  </table>
  </body>
  </html>
  
  '''
# ---
# name: TestDiffSnapshots.test_compute_side_by_side_render
  '''
                  Original                 |                 Modified                
  -----------------------------------------|-----------------------------------------
  alpha                                      alpha                                   
  beta                                     ~ BETA                                    
  gamma                                      gamma                                   
  delta                                      delta                                   
                                           + epsilon                                 
  '''
# ---
# name: TestDiffSnapshots.test_compute_unified_diff_render
  '''
  --- original
  +++ modified
  @@ -1,4 +1,5 @@
   alpha
  -beta
  +BETA
   gamma
   delta
  +epsilon
  
  '''
# ---
# name: TestDiffSnapshots.test_generate_conflict_markers_render
  '''
  alpha
  <<<<<<< ORIGINAL
  beta
  =======
  BETA
  >>>>>>> MODIFIED
  gamma
  delta
  <<<<<<< ORIGINAL
  =======
  epsilon
  >>>>>>> MODIFIED
  '''
# ---
# name: TestDiffSnapshots.test_get_change_summary_render
  '+1 added, ~1 modified'
# ---
# name: TestExportSnapshots.test_export_html_dark_basic
  '''
  <!DOCTYPE html>
  <html lang="en">
  <head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0">
      <meta name="generator" content="RNV Text Transformer">
      <title>Text Transformer Export</title>
      <style>
          * {
              margin: 0;
              padding: 0;
              box-sizing: border-box;
          }
          body {
              font-family: Arial, sans-serif;
              font-size: 11pt;
              line-height: 1.6;
              color: #E0E0E0;
              background-color: #1A1A1A;
              padding: 20px;
          }
          h1 {
              text-align: center;
              color: #d2bc93;
              margin-bottom: 20px;
              font-size: 1.5em;
          }
          .content {
              font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
              white-space: pre-wrap;
              word-wrap: break-word;
              background-color: #1A1A1A;
              padding: 15px;
              border: 1px solid #888888;
              border-radius: 4px;
          }
          .line-num {
              color: #888888;
              user-select: none;
              margin-right: 10px;
          }
          .metadata {
              font-size: 0.8em;
              color: #888888;
              text-align: center;
              margin-top: 20px;
          }
          </style>
  </head>
  <body>
      <h1>Text Transformer Export</h1>
      <pre class="content">Hello World
  Line 2
  Line 3</pre>
      
  </body>
  </html>
  
  '''
