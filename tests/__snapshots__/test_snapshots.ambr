# serializer version: 1
# name: TestDialogStyleSnapshots.test_dialog_stylesheet_dark_arial
  '''
  
              /* ===== BASE DIALOG ===== */
              QDialog {
                  background-color: #1A1A1A;
                  color: #E0E0E0;
                  font-family: 'Arial';
              }
              
              /* ===== LABELS ===== */
              QLabel {
                  color: #E0E0E0;
                  background-color: transparent;
              }
              
              /* ===== GROUP BOX ===== */
              QGroupBox {
                  font-weight: bold;
                  border: 1px solid #333333;
                  border-radius: 4px;
                  margin-top: 10px;
                  padding-top: 10px;
                  color: #d2bc93;
              }
              QGroupBox::title {
                  subcontrol-origin: margin;
                  left: 10px;
                  padding: 0 5px;
              }
              
              /* ===== LINE EDIT ===== */
              QLineEdit {
                  background-color: #2A2A2A;
                  color: #E0E0E0;
                  border: 1px solid #333333;
                  padding: 8px;
                  border-radius: 4px;
                  selection-background-color: #d2bc93;
                  selection-color: #000000;
              }
              QLineEdit:focus {
                  border-color: #d2bc93;
              }
              QLineEdit:disabled {
                  background-color: #333333;
                  color: #555555;
              }
              QLineEdit[readOnly="true"] {
                  background-color: #333333;
              }
              
              /* ===== TEXT EDIT / PLAIN TEXT EDIT ===== */
              QTextEdit, QPlainTextEdit {
                  background-color: #2A2A2A;
                  color: #E0E0E0;
                  border: 1px solid #333333;
                  border-radius: 4px;
                  padding: 4px;
                  selection-background-color: #d2bc93;
                  selection-color: #000000;
              }
              QTextEdit:focus, QPlainTextEdit:focus {
                  border-color: #d2bc93;
              }
              QTextEdit:disabled, QPlainTextEdit:disabled {
                  background-color: #333333;
                  color: #555555;
              }
              
              /* ===== COMBO BOX ===== */
              QComboBox {
                  background-color: #2A2A2A;
                  color: #E0E0E0;
                  border: 1px solid #333333;
                  padding: 5px 10px;
                  border-radius: 4px;
                  min-height: 20px;
              }
              QComboBox:focus {
                  border-color: #d2bc93;
              }
              QComboBox::drop-down {
                  border: none;
                  width: 20px;
              }
              QComboBox::down-arrow {
                  width: 12px;
                  height: 12px;
              }
              QComboBox QAbstractItemView {
                  background-color: #2A2A2A;
                  color: #E0E0E0;
                  selection-background-color: #d2bc93;
                  selection-color: #000000;
                  border: 1px solid #333333;
                  outline: none;
              }
              QComboBox QAbstractItemView::item {
                  padding: 4px 8px;
                  min-height: 22px;
              }
              QComboBox QAbstractItemView::item:selected {
                  background-color: #d2bc93;
                  color: #000000;
              }
              QComboBox QAbstractItemView::item:hover {
                  background-color: #dcc9a3;
                  color: #000000;
              }
              QComboBox:disabled {
                  background-color: #333333;
                  color: #555555;
              }
              
              /* ===== CHECK BOX ===== */
              QCheckBox {
                  color: #E0E0E0;
                  spacing: 8px;
              }
              QCheckBox::indicator {
                  width: 16px;
                  height: 16px;
                  border-radius: 3px;
                  border: 1px solid #444444;
                  background-color: #2A2A2A;
              }
              QCheckBox::indicator:checked {
                  background-color: #d2bc93;
                  border-color: #d2bc93;
              }
              QCheckBox::indicator:hover {
                  border-color: #d2bc93;
              }
              QCheckBox:disabled {
                  color: #555555;
              }
              
              /* ===== RADIO BUTTON ===== */
              QRadioButton {
                  color: #E0E0E0;
                  spacing: 8px;
              }
              QRadioButton::indicator {
                  width: 16px;
                  height: 16px;
                  border-radius: 8px;
                  border: 1px solid #444444;
                  background-color: #2A2A2A;
              }
              QRadioButton::indicator:checked {
                  background-color: #d2bc93;
                  border-color: #d2bc93;
              }
              QRadioButton::indicator:hover {
                  border-color: #d2bc93;
              }
              QRadioButton:disabled {
                  color: #555555;
              }
              
              /* ===== PUSH BUTTON ===== */
              QPushButton {
                  background-color: #2A2A2A;
                  color: #E0E0E0;
                  border: 1px solid #333333;
                  padding: 8px 16px;
                  border-radius: 4px;
                  font-weight: bold;
              }
              QPushButton:hover {
                  background-color: #3A3A3A;
                  border-color: #d2bc93;
                  color: #d2bc93;
              }
              QPushButton:pressed {
                  background-color: #d2bc93;
                  color: #000000;
              }
              QPushButton:disabled {
                  background-color: #333333;
                  color: #555555;
                  border-color: #333333;
              }
              QPushButton:default {
                  border-color: #d2bc93;
              }
              
              /* ===== PROGRESS BAR ===== */
              QProgressBar {
                  background-color: #2A2A2A;
                  border: 1px solid #333333;
                  border-radius: 4px;
                  text-align: center;
                  color: #E0E0E0;
              }
              QProgressBar::chunk {
                  background-color: #d2bc93;
                  border-radius: 3px;
              }
              
              /* ===== SCROLL AREA ===== */
              QScrollArea {
                  border: none;
                  background-color: transparent;
              }
              QScrollArea > QWidget > QWidget {
                  background-color: transparent;
              }
              
              /* ===== SCROLL BAR ===== */
              QScrollBar:vertical {
                  background-color: #252525;
                  width: 12px;
                  border-radius: 6px;
                  margin: 0;
              }
              QScrollBar::handle:vertical {
                  background-color: #444444;
                  border-radius: 5px;
                  min-height: 20px;
                  margin: 2px;
              }
              QScrollBar::handle:vertical:hover {
                  background-color: #d2bc93;
              }
              QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
                  height: 0px;
              }
              QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
                  background: none;
              }
              
              QScrollBar:horizontal {
                  background-color: #252525;
                  height: 12px;
                  border-radius: 6px;
                  margin: 0;
              }
              QScrollBar::handle:horizontal {
                  background-color: #444444;
                  border-radius: 5px;
                  min-width: 20px;
                  margin: 2px;
              }
              QScrollBar::handle:horizontal:hover {
                  background-color: #d2bc93;
              }
              QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
                  width: 0px;
              }
              QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
                  background: none;
              }
              
              /* ===== FRAME ===== */
              QFrame {
                  background-color: transparent;
              }
              QFrame[frameShape="4"] {  /* HLine */
                  background-color: #333333;
                  max-height: 1px;
              }
              QFrame[frameShape="5"] {  /* VLine */
                  background-color: #333333;
                  max-width: 1px;
              }
              
          
