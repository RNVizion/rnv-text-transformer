                  background-color: #444444;
                  border-radius: 5px;
                  min-height: 20px;
                  margin: 2px;
              }
              QScrollBar::handle:vertical:hover {
                  background-color: #d2bc93;
              }
              QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
                  height: 0px;
              }
              QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
                  background: none;
              }
              
              QScrollBar:horizontal {
                  background-color: #252525;
                  height: 12px;
                  border-radius: 6px;
                  margin: 0;
              }
              QScrollBar::handle:horizontal {
                  background-color: #444444;
                  border-radius: 5px;
                  min-width: 20px;
                  margin: 2px;
              }
              QScrollBar::handle:horizontal:hover {
                  background-color: #d2bc93;
              }
              QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
                  width: 0px;
              }
              QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
                  background: none;
              }
              
              /* ===== FRAME ===== */
              QFrame {
                  background-color: transparent;
              }
              QFrame[frameShape="4"] {  /* HLine */
                  background-color: #333333;
                  max-height: 1px;
              }
              QFrame[frameShape="5"] {  /* VLine */
                  background-color: #333333;
                  max-width: 1px;
              }
              
          
              QTabWidget {
                  border: none;
              }
              QTabWidget::pane {
                  background-color: #1A1A1A;
                  border: none;
                  border-top: none;
                  padding: 0px;
                  margin: 0px;
              }
              QTabWidget::tab-bar {
                  left: 0px;
              }
              QTabBar {
                  background-color: #1A1A1A;
                  border: none;
                  qproperty-drawBase: 0;
              }
              QTabBar::tab {
                  background-color: #2A2A2A;
                  color: #888888;
                  padding: 8px 16px;
                  border: none;
                  border-bottom: 2px solid transparent;
                  border-top-left-radius: 4px;
                  border-top-right-radius: 4px;
                  margin-right: 2px;
              }
              QTabBar::tab:selected {
                  background-color: #1A1A1A;
                  color: #d2bc93;
                  border-bottom: 2px solid #d2bc93;
              }
              QTabBar::tab:hover:!selected {
                  background-color: #3A3A3A;
                  color: #d2bc93;
                  border-bottom: 2px solid #b7a480;
              }
          
  
              QTableWidget {
                  background-color: #2A2A2A;
                  color: #E0E0E0;
                  border: 1px solid #333333;
                  gridline-color: #333333;
                  border-radius: 4px;
              }
              QTableWidget::item {
                  padding: 4px;
              }
              QTableWidget::item:selected {
                  background-color: #d2bc93;
                  color: #000000;
              }
              QTableWidget::item:hover {
                  background-color: #dcc9a3;
                  color: #000000;
              }
              QHeaderView::section {
                  background-color: #333333;
                  color: #E0E0E0;
                  border: none;
                  border-right: 1px solid #333333;
                  border-bottom: 1px solid #333333;
                  padding: 6px;
                  font-weight: bold;
              }
              QTableCornerButton::section {
                  background-color: #333333;
                  border: none;
              }
          
  
              QListWidget {
                  background-color: #2A2A2A;
                  color: #E0E0E0;
                  border: 1px solid #333333;
                  border-radius: 4px;
                  outline: none;
              }
              QListWidget::item {
                  padding: 6px;
                  border-radius: 2px;
              }
              QListWidget::item:selected {
                  background-color: #d2bc93;
                  color: #000000;
              }
              QListWidget::item:hover:!selected {
                  background-color: #dcc9a3;
                  color: #000000;
              }
          
  
              QTreeWidget {
                  background-color: #2A2A2A;
                  color: #E0E0E0;
                  border: 1px solid #333333;
                  border-radius: 4px;
                  outline: none;
              }
              QTreeWidget::item {
                  padding: 4px;
              }
              QTreeWidget::item:selected {
                  background-color: #d2bc93;
                  color: #000000;
              }
              QTreeWidget::item:hover:!selected {
                  background-color: #dcc9a3;
                  color: #000000;
              }
              QTreeWidget::branch {
                  background-color: transparent;
              }
              QTreeWidget::branch:selected {
                  background-color: #d2bc93;
              }
              QHeaderView::section {
                  background-color: #333333;
                  color: #E0E0E0;
                  border: none;
                  border-right: 1px solid #333333;
                  border-bottom: 1px solid #333333;
                  padding: 6px;
                  font-weight: bold;
              }
          
  
              QSlider::groove:horizontal {
                  border: 1px solid #333333;
                  height: 6px;
                  background: #2A2A2A;
                  border-radius: 3px;
              }
              QSlider::handle:horizontal {
                  background: #d2bc93;
                  border: none;
                  width: 16px;
                  margin: -5px 0;
                  border-radius: 8px;
              }
              QSlider::handle:horizontal:hover {
                  background: #dcc9a3;
              }
              QSlider::sub-page:horizontal {
                  background: #d2bc93;
                  border-radius: 3px;
              }
              QSlider::groove:vertical {
                  border: 1px solid #333333;
                  width: 6px;
                  background: #2A2A2A;
                  border-radius: 3px;
              }
              QSlider::handle:vertical {
                  background: #d2bc93;
                  border: none;
                  height: 16px;
                  margin: 0 -5px;
                  border-radius: 8px;
              }
              QSlider::handle:vertical:hover {
                  background: #dcc9a3;
              }
          
  
              QSpinBox, QDoubleSpinBox {
                  background-color: #2A2A2A;
                  color: #E0E0E0;
                  border: 1px solid #333333;
                  padding: 5px;
                  border-radius: 4px;
                  selection-background-color: #d2bc93;
                  selection-color: #000000;
              }
              QSpinBox:focus, QDoubleSpinBox:focus {
                  border-color: #d2bc93;
              }
              QSpinBox::up-button, QDoubleSpinBox::up-button {
                  border: none;
                  background-color: transparent;
              }
              QSpinBox::down-button, QDoubleSpinBox::down-button {
                  border: none;
                  background-color: transparent;
              }
              QSpinBox:disabled, QDoubleSpinBox:disabled {
                  background-color: #333333;
                  color: #555555;
              }
          
  
              QMenu {
                  background-color: #2A2A2A;
                  color: #E0E0E0;
                  border: 1px solid #333333;
                  padding: 4px;
              }
              QMenu::item {
                  padding: 6px 24px 6px 12px;
                  border-radius: 2px;
              }
              QMenu::item:selected {
                  background-color: #d2bc93;
                  color: #000000;
              }
              QMenu::item:disabled {
                  color: #555555;
              }
              QMenu::separator {
                  height: 1px;
                  background-color: #333333;
                  margin: 4px 8px;
              }
          
  
              QSplitter::handle {
                  background-color: #333333;
              }
              QSplitter::handle:horizontal {
                  width: 3px;
              }
              QSplitter::handle:vertical {
                  height: 3px;
              }
              QSplitter::handle:hover {
                  background-color: #d2bc93;
              }
          
  
              QProgressBar {
                  background-color: #2A2A2A;
                  border: 1px solid #333333;
                  border-radius: 4px;
                  text-align: center;
                  color: #E0E0E0;
                  height: 20px;
              }
              QProgressBar::chunk {
                  background-color: #d2bc93;
                  border-radius: 3px;
              }
          
