# =============================================================================
# Python
# =============================================================================

# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
develop-eggs/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
wheelhouse/
share/python-wheels/
*.manifest

# PyInstaller — produced by build_windows.bat / build_linux.sh
# The .spec file IS committed; build outputs are not.
*.spec.bak

# =============================================================================
# Virtual environments
# =============================================================================

.venv/
venv/
env/
ENV/
.python-version

# =============================================================================
# Test infrastructure (generated artifacts — do not commit)
# =============================================================================

# Hypothesis: per-machine cache of falsifying examples and database state.
# Hypothesis is deterministic per-seed; the cache is a runtime helper, not
# canonical state. Each developer's cache is local.
.hypothesis/

# pytest-benchmark: per-run timing data files. Saved baselines (e.g. via
# --benchmark-save=baseline) live here and are machine-specific. Each
# developer's baseline reflects their hardware and isn't portable.
.benchmarks/

# pytest cache
.pytest_cache/

# coverage.py per-suite data files — these are merged into .coverage by
# run_tests.py. Both the per-suite files AND the merged file should not
# be committed.
.coverage
.coverage.*
coverage_html/
coverage_report.txt

# CI-generated coverage XML uploaded to Codecov
coverage.xml

# syrupy snapshot test ambient artifacts (the __snapshots__ folders ARE
# committed — they're the snapshot baselines. Only the .ambr lock files
# and per-run reports should be ignored.)
**/__snapshots__/*.ambr.bak

# Mutmut cache (mutation testing tool)
.mutmut-cache
mutants/

# =============================================================================
# IDEs & editors
# =============================================================================

# Visual Studio Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# =============================================================================
