# =============================================================================

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns

# Linux
.directory
.Trash-*

# =============================================================================
# Logs & temp files
# =============================================================================

*.log
*.tmp
*.temp
*.bak
*.orig
*.rej
*~

# =============================================================================
# Project-specific
# =============================================================================

# Internal planning / scaffolding docs (never committed to portfolio repo)
RNV_Phase*_Analysis.md
RNV_Test_Mutation_Audit.md

# Production-fix staging files from the test plan
*_PATCHED.py

# Phase deliverable bundles
phase8*/
*.zip

# Local QSettings backup files
*.ini.bak

# User-specific runtime files
user_presets.json.bak
watch_rules.json.bak
